{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compileOnSave": true,
  "compilerOptions": {
    "types": [
      "node"
    ],
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist",

    "resolveJsonModule": true,

    // TypeORM requirement
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true
  },
  "include": [
    "src",
    "src/**/*.json"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/*",
    "src/**/*.example.json"
  ]
}